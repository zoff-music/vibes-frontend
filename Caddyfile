:3000 {
	# Redirect /casting/receiver to /casting/receiver/
	redir /casting/receiver /casting/receiver/

	# Cast Assets - serve from /srv/cast-app
	handle /assets/cast/* {
		root * /srv/cast-app
		file_server
	}

	# Cast Receiver App
	# Serves /casting/receiver/* from /srv/cast-app
	# Uses handle_path to strip the prefix
	# Cast Receiver App
	# Serves /casting/receiver/* via proxy to dev server (for HMR)
	handle /casting/receiver/* {
		reverse_proxy 127.0.0.1:3003 {
			header_up Host {host}
			header_up X-Real-IP {remote}
			header_up X-Forwarded-For {remote}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Main Platform App
	# Serves /* from /srv/app
	handle {
		root * /srv/app
		try_files {path} {path}/ /index.html
		file_server
	}

	# Logging
	log {
		output stderr
		format json
	}
}
